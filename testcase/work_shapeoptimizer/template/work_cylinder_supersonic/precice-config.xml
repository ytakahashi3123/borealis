<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration>
  <log>
    <sink
      filter="%Severity% > debug and %Rank% = 0"
      format="---[precice] %ColorizedSeverity% %Message%"
      enabled="true" />
  </log>

  <profiling mode="fundamental" synchronize="false" />

  <data:vector name="Force" />
  <data:vector name="Displacement" />

  <mesh name="Fluid-Mesh" dimensions="2">
    <use-data name="Force" />
    <use-data name="Displacement" />
  </mesh>

  <mesh name="Optimizer-Mesh" dimensions="2">
    <use-data name="Displacement" />
    <use-data name="Force" />
  </mesh>

  <participant name="Fluid">
    <provide-mesh name="Fluid-Mesh" />
    <receive-mesh name="Optimizer-Mesh" from="Optimizer" />
    <write-data name="Force" mesh="Fluid-Mesh" />
    <read-data name="Displacement" mesh="Fluid-Mesh" />
    <mapping:rbf-global-direct direction="write" from="Fluid-Mesh" to="Optimizer-Mesh" constraint="conservative">
      <basis-function:thin-plate-splines />
<!--
      <basis-function:compact-polynomial-c6 support-radius="0.1" />
-->
    </mapping:rbf-global-direct>
    <mapping:rbf-global-direct direction="read" from="Optimizer-Mesh" to="Fluid-Mesh" constraint="consistent">
      <basis-function:thin-plate-splines />
<!--
      <basis-function:compact-polynomial-c6 support-radius="0.1" />
-->
    </mapping:rbf-global-direct>
  </participant>

  <participant name="Optimizer">
    <provide-mesh name="Optimizer-Mesh" />
    <write-data name="Displacement" mesh="Optimizer-Mesh" />
    <read-data name="Force" mesh="Optimizer-Mesh" />
    <watch-point mesh="Optimizer-Mesh" name="point1" coordinate="0.0;0.0" />
  </participant>

  <m2n:sockets acceptor="Fluid" connector="Optimizer" network="lo" exchange-directory="../"/>

  <coupling-scheme:parallel-implicit>
    <participants first="Fluid" second="Optimizer"/>
    <max-time-windows value="300" />
    <time-window-size value="1.0e-3" />
    <exchange data="Force" mesh="Optimizer-Mesh" from="Fluid" to="Optimizer" initialize="yes"/>
    <exchange data="Displacement" mesh="Optimizer-Mesh" from="Optimizer" to="Fluid" initialize="yes"/>
    <max-iterations value="2"/>
    <relative-convergence-measure limit="1e-3" data="Displacement" mesh="Optimizer-Mesh"/>
    <relative-convergence-measure limit="1e-3" data="Force" mesh="Optimizer-Mesh"/>
<!--
    <acceleration:IQN-ILS>
      <data name="Displacement" mesh="Optimizer-Mesh"/>
      <data name="Force" mesh="Optimizer-Mesh"/>
      <preconditioner type="residual-sum"/>
      <filter type="QR1" limit="1e-6"/>
      <initial-relaxation value="0.5"/>
      <max-used-iterations value="40"/>
      <time-windows-reused value="10"/>
    </acceleration:IQN-ILS>
-->
  </coupling-scheme:parallel-implicit>

<!--
  <coupling-scheme:serial-explicit>
    <participants first="Fluid" second="Optimizer"/>
    <max-time-windows value="300" />
    <time-window-size value="1.0e-4" />
    <exchange data="Force" mesh="Optimizer-Mesh" from="Fluid" to="Optimizer" initialize="yes"/>
    <exchange data="Displacement" mesh="Optimizer-Mesh" from="Optimizer" to="Fluid" initialize="yes" />
  </coupling-scheme:serial-explicit>
-->
</precice-configuration>

